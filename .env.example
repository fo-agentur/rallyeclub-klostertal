# Admin password hash — generate with: npm run hash-password <your-password>
ADMIN_PASSWORD_HASH=

# Secret used to sign session cookies — generate with: openssl rand -base64 32
AUTH_SECRET=

# Supabase (Postgres + Storage) — Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Server-only: service_role key (never NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# --- Vercel (Production / Preview) ---
# Project → Settings → Environment Variables: same keys as above (SUPABASE_*, AUTH_SECRET, ADMIN_PASSWORD_HASH).
# After saving, trigger Redeploy so serverless functions pick up values.
#
# Admin panel: open /admin on your site (e.g. https://rallyeclub-klostertal.vercel.app/admin).
