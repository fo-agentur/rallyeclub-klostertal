# Admin password hash — generate with: npm run hash-password <your-password>
ADMIN_PASSWORD_HASH=

# Secret used to sign session cookies — generate with: openssl rand -base64 32
AUTH_SECRET=

# Supabase (Postgres + Storage) — Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Server-only: service_role key (never NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=
