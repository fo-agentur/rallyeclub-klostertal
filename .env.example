# =============================================================================
# Firebase — öffentliche Web-App (Browser / Client SDK)
# Quelle: Firebase Console → Projekteinstellungen → „Deine Apps“ → Web-App → firebaseConfig
# Alle mit NEXT_PUBLIC_ sind im Build im Client sichtbar — trotzdem keine Secrets aus anderen Diensten hierher legen.
# =============================================================================

# API-Schlüssel der Web-App (nicht der Service Account)
NEXT_PUBLIC_FIREBASE_WEB_API_KEY=

# Login-Host, z. B. dein-projekt.firebaseapp.com
NEXT_PUBLIC_FIREBASE_WEB_AUTH_DOMAIN=

# Projekt-ID (eine Zeichenkette, z. B. rallye-39a9e)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Storage-Bucket (vollständiger Bucket-Name aus der Konsole)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET_URL=

# Absender-ID für Cloud Messaging / SDK-Konfiguration (Zahl als String)
NEXT_PUBLIC_FIREBASE_FCM_SENDER_ID=

# App-ID der Web-App (Format 1:123:web:abc)
NEXT_PUBLIC_FIREBASE_WEB_APP_ID=

# Optional: nur nötig, wenn du Firebase Analytics im Code nutzt
# NEXT_PUBLIC_FIREBASE_ANALYTICS_MEASUREMENT_ID=

# --- Legacy-Namen (weiterhin unterstützt, falls du sie schon nutzt) ---
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# =============================================================================
# Firebase Admin SDK (nur Server: Node / API Routes / ISR) — NIEMALS committen
# Quelle: Console → Projekteinstellungen → Dienstkonten → Neuer privater Schlüssel (JSON)
# Gesamte JSON-Datei als EINE Zeile in Anführungszeichen; private_key-Zeilenumbrüche bleiben \n im String.
# =============================================================================

FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON=

# Legacy-Name (weiterhin unterstützt)
# FIREBASE_SERVICE_ACCOUNT_JSON=
