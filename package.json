{
  "name": "rallyeclub-klostertal-v3",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "cf:build": "opennextjs-cloudflare build",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "start": "next start",
    "lint": "next lint",
    "scrape": "tsx scripts/scrape-legacy.ts",
    "seed": "tsx scripts/seed.ts",
    "seed:d1": "tsx scripts/generate-d1-seed.ts && npx wrangler d1 execute rallyeclub-klostertal-db --file=scripts/d1-seed.sql --remote",
    "hash-password": "tsx scripts/hash-password.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.5.4",
    "yet-another-react-lightbox": "^3.21.7",
    "zod": "^3.23.8"
  },
  "overrides": {
    "@dotenvx/dotenvx": "^1.61.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260415.1",
    "@opennextjs/cloudflare": "^1.19.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "wrangler": "^4.82.2"
  }
}
